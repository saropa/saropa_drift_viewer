#!/bin/sh

# Pre-commit hook: Run TypeScript type checking on the extension
# This catches type errors BEFORE they get committed

echo "🔍 Running TypeScript lint check on extension..."

cd extension || exit 1

# Run tsc --noEmit to check for type errors without generating output
# Exit immediately if lint fails
npm run lint || {
  echo ""
  echo "❌ TypeScript errors detected! Fix the errors above before committing."
  echo ""
  echo "   To see errors:  cd extension && npm run lint"
  echo "   To compile:     cd extension && npm run compile"
  echo ""
  exit 1
}

echo "✅ TypeScript check passed"
