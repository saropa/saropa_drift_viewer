{
  "name": "drift-viewer",
  "displayName": "Drift Viewer",
  "description": "Open the Drift debug viewer (saropa_drift_viewer) in the browser.",
  "version": "0.1.0",
  "publisher": "saropa",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Other"],
  "activationEvents": ["onCommand:driftViewer.openInBrowser"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "driftViewer.openInBrowser", "title": "Drift Viewer: Open in Browser" }
    ],
    "configuration": {
      "title": "Drift Viewer",
      "properties": {
        "driftViewer.port": {
          "type": "number",
          "default": 8642,
          "description": "Port of the Drift debug server."
        },
        "driftViewer.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host of the Drift debug server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
