{
  "name": "drift-advisor",
  "displayName": "Saropa Drift Advisor",
  "description": "Debug SQLite/Drift databases in VS Code with Saropa Drift Advisor.",
  "version": "1.0.0",
  "publisher": "saropa",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/saropa/saropa_drift_advisor"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:dart"
  ],
  "icon": "icon.png",
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "driftViewer",
          "title": "Saropa Drift Advisor",
          "icon": "$(database)"
        }
      ]
    },
    "views": {
      "driftViewer": [
        {
          "id": "driftViewer.schemaSearch",
          "name": "Schema Search",
          "icon": "$(search)",
          "type": "webview",
          "when": "driftViewer.serverConnected"
        },
        {
          "id": "driftViewer.databaseExplorer",
          "name": "Database",
          "icon": "$(database)"
        },
        {
          "id": "driftViewer.pendingChanges",
          "name": "Pending Changes",
          "icon": "$(edit)",
          "when": "driftViewer.hasEdits"
        }
      ],
      "debug": [
        {
          "id": "driftViewer.queryPerformance",
          "name": "Drift Queries",
          "icon": "$(dashboard)",
          "when": "inDebugMode && driftViewer.serverConnected"
        }
      ]
    },
    "commands": [
      {
        "command": "driftViewer.openInBrowser",
        "title": "Saropa Drift Advisor: Open in Browser"
      },
      {
        "command": "driftViewer.openInPanel",
        "title": "Saropa Drift Advisor: Open in Editor Panel"
      },
      {
        "command": "driftViewer.refreshTree",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "driftViewer.viewTableData",
        "title": "View Table Data"
      },
      {
        "command": "driftViewer.copyTableName",
        "title": "Copy Table Name"
      },
      {
        "command": "driftViewer.exportTable",
        "title": "Export Table…",
        "icon": "$(export)"
      },
      {
        "command": "driftViewer.copyColumnName",
        "title": "Copy Column Name"
      },
      {
        "command": "driftViewer.filterByColumn",
        "title": "Filter by Column"
      },
      {
        "command": "driftViewer.saveFilter",
        "title": "Saropa Drift Advisor: Save Current Filter"
      },
      {
        "command": "driftViewer.viewTableInPanel",
        "title": "Saropa Drift Advisor: View Table"
      },
      {
        "command": "driftViewer.runTableQuery",
        "title": "Saropa Drift Advisor: Run Table Query"
      },
      {
        "command": "driftViewer.refreshPerformance",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "driftViewer.clearPerformance",
        "title": "Saropa Drift Advisor: Clear Query Stats",
        "icon": "$(trash)"
      },
      {
        "command": "driftViewer.showQueryDetail",
        "title": "Saropa Drift Advisor: Show Query Detail"
      },
      {
        "command": "driftViewer.runLinter",
        "title": "Saropa Drift Advisor: Run Schema Linter"
      },
      {
        "command": "driftViewer.copySuggestedSql",
        "title": "Saropa Drift Advisor: Copy Suggested SQL"
      },
      {
        "command": "driftViewer.selectServer",
        "title": "Saropa Drift Advisor: Select Server"
      },
      {
        "command": "driftViewer.retryDiscovery",
        "title": "Saropa Drift Advisor: Retry Server Discovery"
      },
      {
        "command": "driftViewer.showAllTables",
        "title": "Saropa Drift Advisor: Show All Tables"
      },
      {
        "command": "driftViewer.captureSnapshot",
        "title": "Saropa Drift Advisor: Capture Snapshot"
      },
      {
        "command": "driftViewer.showSnapshotDiff",
        "title": "Saropa Drift Advisor: Show Snapshot Diff"
      },
      {
        "command": "driftViewer.explainQuery",
        "title": "Saropa Drift Advisor: Explain Query Plan"
      },
      {
        "command": "driftViewer.analyzeQueryCost",
        "title": "Saropa Drift Advisor: Analyze Query Cost",
        "icon": "$(pulse)"
      },
      {
        "command": "driftViewer.watchTable",
        "title": "Watch Table",
        "icon": "$(eye)"
      },
      {
        "command": "driftViewer.watchQuery",
        "title": "Saropa Drift Advisor: Watch Query"
      },
      {
        "command": "driftViewer.openWatchPanel",
        "title": "Saropa Drift Advisor: Open Watch Panel"
      },
      {
        "command": "driftViewer.generateSql",
        "title": "Saropa Drift Advisor: Generate SQL from Edits",
        "icon": "$(file-code)"
      },
      {
        "command": "driftViewer.discardAllEdits",
        "title": "Saropa Drift Advisor: Discard All Edits",
        "icon": "$(trash)"
      },
      {
        "command": "driftViewer.undoEdit",
        "title": "Saropa Drift Advisor: Undo Edit"
      },
      {
        "command": "driftViewer.redoEdit",
        "title": "Saropa Drift Advisor: Redo Edit"
      },
      {
        "command": "driftViewer.toggleEditing",
        "title": "Saropa Drift Advisor: Toggle Editing Mode"
      },
      {
        "command": "driftViewer.removeChange",
        "title": "Remove Change",
        "icon": "$(close)"
      },
      {
        "command": "driftViewer.openSqlNotebook",
        "title": "Saropa Drift Advisor: Open SQL Notebook",
        "icon": "$(terminal)"
      },
      {
        "command": "driftViewer.schemaDiff",
        "title": "Saropa Drift Advisor: Schema Diff (Code vs Runtime)"
      },
      {
        "command": "driftViewer.generateDart",
        "title": "Saropa Drift Advisor: Generate Dart from Schema"
      },
      {
        "command": "driftViewer.exportDump",
        "title": "Saropa Drift Advisor: Export SQL Dump"
      },
      {
        "command": "driftViewer.downloadDatabase",
        "title": "Saropa Drift Advisor: Download Database File"
      },
      {
        "command": "driftViewer.migrationPreview",
        "title": "Saropa Drift Advisor: Preview Migration SQL"
      },
      {
        "command": "driftViewer.compareReport",
        "title": "Saropa Drift Advisor: Compare Databases"
      },
      {
        "command": "driftViewer.schemaDiagram",
        "title": "Saropa Drift Advisor: Schema Diagram"
      },
      {
        "command": "driftViewer.sizeAnalytics",
        "title": "Saropa Drift Advisor: Database Size Analytics"
      },
      {
        "command": "driftViewer.generateSchemaDocs",
        "title": "Saropa Drift Advisor: Generate Schema Documentation",
        "icon": "$(book)"
      },
      {
        "command": "driftViewer.importData",
        "title": "Saropa Drift Advisor: Import Data"
      },
      {
        "command": "driftViewer.shareSession",
        "title": "Saropa Drift Advisor: Share Debug Session"
      },
      {
        "command": "driftViewer.openSession",
        "title": "Saropa Drift Advisor: Open Shared Session"
      },
      {
        "command": "driftViewer.annotateSession",
        "title": "Saropa Drift Advisor: Annotate Session"
      },
      {
        "command": "driftViewer.seedTable",
        "title": "Saropa Drift Advisor: Seed Test Data",
        "icon": "$(beaker)"
      },
      {
        "command": "driftViewer.seedAllTables",
        "title": "Saropa Drift Advisor: Seed All Tables"
      },
      {
        "command": "driftViewer.clearTable",
        "title": "Saropa Drift Advisor: Clear Table Data",
        "icon": "$(trash)"
      },
      {
        "command": "driftViewer.clearAllTables",
        "title": "Saropa Drift Advisor: Clear All Table Data"
      },
      {
        "command": "driftViewer.clearTableGroup",
        "title": "Saropa Drift Advisor: Clear Table Group"
      },
      {
        "command": "driftViewer.importDataset",
        "title": "Saropa Drift Advisor: Import Dataset",
        "icon": "$(cloud-download)"
      },
      {
        "command": "driftViewer.exportDataset",
        "title": "Saropa Drift Advisor: Export Current Data as Dataset",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "driftViewer.globalSearch",
        "title": "Saropa Drift Advisor: Search All Tables",
        "icon": "$(search)"
      },
      {
        "command": "driftViewer.compareRows",
        "title": "Saropa Drift Advisor: Compare Two Rows",
        "icon": "$(diff)"
      },
      {
        "command": "driftViewer.profileColumn",
        "title": "Saropa Drift Advisor: Profile Column",
        "icon": "$(graph)"
      },
      {
        "command": "driftViewer.snapshotChangelog",
        "title": "Saropa Drift Advisor: Generate Snapshot Changelog",
        "icon": "$(list-ordered)"
      },
      {
        "command": "driftViewer.annotateTable",
        "title": "Annotate Table",
        "icon": "$(bookmark)"
      },
      {
        "command": "driftViewer.annotateColumn",
        "title": "Annotate Column",
        "icon": "$(bookmark)"
      },
      {
        "command": "driftViewer.openBookmarks",
        "title": "Saropa Drift Advisor: Open Bookmarks",
        "icon": "$(bookmark)"
      },
      {
        "command": "driftViewer.exportAnnotations",
        "title": "Saropa Drift Advisor: Export Annotations"
      },
      {
        "command": "driftViewer.importAnnotations",
        "title": "Saropa Drift Advisor: Import Annotations"
      },
      {
        "command": "driftViewer.addDataBreakpoint",
        "title": "Add Data Breakpoint",
        "icon": "$(debug-breakpoint-data)"
      },
      {
        "command": "driftViewer.removeDataBreakpoint",
        "title": "Saropa Drift Advisor: Remove Data Breakpoint"
      },
      {
        "command": "driftViewer.toggleDataBreakpoint",
        "title": "Saropa Drift Advisor: Toggle Data Breakpoint"
      },
      {
        "command": "driftViewer.generateMigration",
        "title": "Saropa Drift Advisor: Generate Migration Code",
        "icon": "$(file-code)"
      },
      {
        "command": "driftViewer.constraintWizard",
        "title": "Saropa Drift Advisor: Constraint Wizard",
        "icon": "$(shield)"
      },
      {
        "command": "driftViewer.analyzeRowImpact",
        "title": "Saropa Drift Advisor: Analyze Row Impact",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "driftViewer.isarToDrift",
        "title": "Saropa Drift Advisor: Generate Drift from Isar Schema",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "driftViewer.openSnippetLibrary",
        "title": "Saropa Drift Advisor: Open SQL Snippet Library",
        "icon": "$(notebook)"
      },
      {
        "command": "driftViewer.saveAsSnippet",
        "title": "Saropa Drift Advisor: Save Query as Snippet"
      },
      {
        "command": "driftViewer.pinTable",
        "title": "Pin Table",
        "icon": "$(pin)"
      },
      {
        "command": "driftViewer.unpinTable",
        "title": "Unpin Table",
        "icon": "$(pinned)"
      },
      {
        "command": "driftViewer.healthScore",
        "title": "Saropa Drift Advisor: Database Health Score",
        "icon": "$(heart)"
      },
      {
        "command": "driftViewer.openDashboard",
        "title": "Saropa Drift Advisor: Open Dashboard",
        "icon": "$(dashboard)"
      },
      {
        "command": "driftViewer.saveDashboard",
        "title": "Saropa Drift Advisor: Save Dashboard Layout"
      },
      {
        "command": "driftViewer.loadDashboard",
        "title": "Saropa Drift Advisor: Load Dashboard Layout"
      },
      {
        "command": "driftViewer.deleteDashboard",
        "title": "Saropa Drift Advisor: Delete Dashboard Layout"
      },
      {
        "command": "driftViewer.manageInvariants",
        "title": "Saropa Drift Advisor: Manage Data Invariants",
        "icon": "$(shield)"
      },
      {
        "command": "driftViewer.addInvariant",
        "title": "Saropa Drift Advisor: Add Data Invariant"
      },
      {
        "command": "driftViewer.runAllInvariants",
        "title": "Saropa Drift Advisor: Run All Invariants"
      },
      {
        "command": "driftViewer.narrateRow",
        "title": "Tell This Row's Story",
        "icon": "$(book)"
      },
      {
        "command": "driftViewer.showErDiagram",
        "title": "Saropa Drift Advisor: Show ER Diagram",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "driftViewer.clipboardImport",
        "title": "Paste from Clipboard",
        "icon": "$(clippy)"
      },
      {
        "command": "driftViewer.undoClipboardImport",
        "title": "Saropa Drift Advisor: Undo Clipboard Import"
      },
      {
        "command": "driftViewer.showImportHistory",
        "title": "Saropa Drift Advisor: Show Import History"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "driftViewer.refreshTree",
          "when": "view == driftViewer.databaseExplorer",
          "group": "navigation"
        },
        {
          "command": "driftViewer.generateSchemaDocs",
          "when": "view == driftViewer.databaseExplorer && driftViewer.serverConnected",
          "group": "navigation"
        },
        {
          "command": "driftViewer.refreshPerformance",
          "when": "view == driftViewer.queryPerformance",
          "group": "navigation"
        },
        {
          "command": "driftViewer.clearPerformance",
          "when": "view == driftViewer.queryPerformance",
          "group": "navigation"
        },
        {
          "command": "driftViewer.generateSql",
          "when": "view == driftViewer.pendingChanges",
          "group": "navigation"
        },
        {
          "command": "driftViewer.discardAllEdits",
          "when": "view == driftViewer.pendingChanges",
          "group": "navigation"
        },
        {
          "command": "driftViewer.importDataset",
          "when": "view == driftViewer.databaseExplorer && driftViewer.serverConnected",
          "group": "navigation"
        },
        {
          "command": "driftViewer.globalSearch",
          "when": "view == driftViewer.databaseExplorer && driftViewer.serverConnected",
          "group": "navigation"
        },
        {
          "command": "driftViewer.openBookmarks",
          "when": "view == driftViewer.databaseExplorer",
          "group": "navigation"
        },
        {
          "command": "driftViewer.isarToDrift",
          "when": "view == driftViewer.databaseExplorer",
          "group": "navigation"
        },
        {
          "command": "driftViewer.openSnippetLibrary",
          "when": "view == driftViewer.databaseExplorer && driftViewer.serverConnected",
          "group": "navigation"
        },
        {
          "command": "driftViewer.healthScore",
          "when": "view == driftViewer.databaseExplorer && driftViewer.serverConnected",
          "group": "navigation"
        },
        {
          "command": "driftViewer.openDashboard",
          "when": "view == driftViewer.databaseExplorer && driftViewer.serverConnected",
          "group": "navigation"
        },
        {
          "command": "driftViewer.manageInvariants",
          "when": "view == driftViewer.databaseExplorer && driftViewer.serverConnected",
          "group": "navigation"
        },
        {
          "command": "driftViewer.showErDiagram",
          "when": "view == driftViewer.databaseExplorer && driftViewer.serverConnected",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "driftViewer.explainQuery",
          "when": "editorLangId == dart",
          "group": "drift@1"
        }
      ],
      "view/item/context": [
        {
          "command": "driftViewer.pinTable",
          "when": "viewItem == driftTable",
          "group": "0_pin"
        },
        {
          "command": "driftViewer.unpinTable",
          "when": "viewItem == driftTablePinned",
          "group": "0_pin"
        },
        {
          "command": "driftViewer.viewTableData",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "1_view"
        },
        {
          "command": "driftViewer.copyTableName",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "2_copy"
        },
        {
          "command": "driftViewer.exportTable",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "3_export"
        },
        {
          "command": "driftViewer.copyColumnName",
          "when": "viewItem == driftColumn || viewItem == driftColumnPk",
          "group": "2_copy"
        },
        {
          "command": "driftViewer.filterByColumn",
          "when": "viewItem == driftColumn || viewItem == driftColumnPk",
          "group": "1_view"
        },
        {
          "command": "driftViewer.profileColumn",
          "when": "viewItem == driftColumn || viewItem == driftColumnPk",
          "group": "3_profile"
        },
        {
          "command": "driftViewer.watchTable",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "4_watch"
        },
        {
          "command": "driftViewer.compareRows",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "5_compare"
        },
        {
          "command": "driftViewer.seedTable",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "6_data"
        },
        {
          "command": "driftViewer.clearTable",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "6_data"
        },
        {
          "command": "driftViewer.clipboardImport",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "6_data"
        },
        {
          "command": "driftViewer.addDataBreakpoint",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "7_breakpoint"
        },
        {
          "command": "driftViewer.addInvariant",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "9_invariant"
        },
        {
          "command": "driftViewer.constraintWizard",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "9_constraints"
        },
        {
          "command": "driftViewer.analyzeRowImpact",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "5_analysis"
        },
        {
          "command": "driftViewer.narrateRow",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "5_analysis"
        },
        {
          "command": "driftViewer.annotateTable",
          "when": "viewItem == driftTable || viewItem == driftTablePinned",
          "group": "8_annotate"
        },
        {
          "command": "driftViewer.annotateColumn",
          "when": "viewItem == driftColumn || viewItem == driftColumnPk",
          "group": "8_annotate"
        },
        {
          "command": "driftViewer.removeChange",
          "when": "viewItem == pendingChange",
          "group": "inline"
        }
      ]
    },
    "keybindings": [
      {
        "command": "driftViewer.undoEdit",
        "key": "ctrl+z",
        "when": "driftViewer.editingActive && focusedView == driftViewer.pendingChanges"
      },
      {
        "command": "driftViewer.redoEdit",
        "key": "ctrl+shift+z",
        "when": "driftViewer.editingActive && focusedView == driftViewer.pendingChanges"
      },
      {
        "command": "driftViewer.openSqlNotebook",
        "key": "ctrl+shift+q",
        "mac": "cmd+shift+q",
        "when": "driftViewer.serverConnected"
      },
      {
        "command": "driftViewer.globalSearch",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "driftViewer.serverConnected"
      }
    ],
    "taskDefinitions": [
      {
        "type": "drift",
        "required": [
          "check"
        ],
        "properties": {
          "check": {
            "type": "string",
            "enum": [
              "healthCheck",
              "anomalyScan",
              "indexCoverage"
            ],
            "description": "Which health check to run."
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "drift-health",
        "owner": "driftViewer",
        "pattern": {
          "regexp": "^\\s*[✗⚠]\\s+(.+\\.\\w+):\\s+(.+)$",
          "file": 1,
          "message": 2
        },
        "severity": "warning"
      }
    ],
    "configuration": {
      "title": "Saropa Drift Advisor",
      "properties": {
        "driftViewer.authToken": {
          "type": "string",
          "default": "",
          "description": "Bearer token for authenticating with the Drift debug server."
        },
        "driftViewer.port": {
          "type": "number",
          "default": 8642,
          "description": "Port of the Drift debug server."
        },
        "driftViewer.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host of the Drift debug server."
        },
        "driftViewer.discovery.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan for running Drift debug servers."
        },
        "driftViewer.discovery.portRangeStart": {
          "type": "number",
          "default": 8642,
          "description": "Start of port range to scan for Drift debug servers."
        },
        "driftViewer.discovery.portRangeEnd": {
          "type": "number",
          "default": 8649,
          "description": "End of port range to scan for Drift debug servers (inclusive)."
        },
        "driftViewer.tasks.blockOnWarnings": {
          "type": "boolean",
          "default": false,
          "description": "Block app launch when health check finds warnings (not just errors)."
        },
        "driftViewer.performance.slowThresholdMs": {
          "type": "number",
          "default": 500,
          "description": "Queries slower than this (ms) are highlighted as slow."
        },
        "driftViewer.performance.refreshIntervalMs": {
          "type": "number",
          "default": 3000,
          "description": "How often to refresh performance data during debug (ms)."
        },
        "driftViewer.performance.logToCapture": {
          "type": "string",
          "enum": [
            "off",
            "slow-only",
            "all"
          ],
          "default": "slow-only",
          "description": "Log queries to Saropa Log Capture: off, slow queries only, or all queries."
        },
        "driftViewer.fileBadges.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show row count badges on Drift table files in the explorer."
        },
        "driftViewer.hover.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show database row preview on hover during debug sessions."
        },
        "driftViewer.hover.maxRows": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Number of recent rows to show in hover preview."
        },
        "driftViewer.linter.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show database diagnostics on Drift table definitions."
        },
        "driftViewer.linter.anomalySeverity": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "information",
            "hint"
          ],
          "default": "warning",
          "description": "Severity level for data anomaly diagnostics."
        },
        "driftViewer.timeline.maxSnapshots": {
          "type": "number",
          "default": 20,
          "description": "Maximum number of snapshots to keep in memory."
        },
        "driftViewer.timeline.autoCapture": {
          "type": "boolean",
          "default": true,
          "description": "Automatically capture snapshots when database data changes."
        },
        "driftViewer.timeline.minIntervalMs": {
          "type": "number",
          "default": 10000,
          "description": "Minimum milliseconds between automatic snapshot captures."
        },
        "driftViewer.watch.notifications": {
          "type": "boolean",
          "default": false,
          "description": "Show desktop notifications when watched data changes."
        },
        "driftViewer.watch.maxWatchers": {
          "type": "number",
          "default": 10,
          "description": "Maximum number of simultaneous watch queries."
        },
        "driftViewer.dataBreakpoints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable data breakpoint evaluation during debug sessions."
        },
        "driftViewer.dataBreakpoints.pollIntervalMs": {
          "type": "number",
          "default": 1000,
          "description": "Minimum interval between breakpoint evaluations (ms)."
        },
        "driftViewer.fkHyperlinks.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show foreign key values as clickable links in table data views."
        },
        "driftViewer.impact.maxDepth": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum FK traversal depth for row impact analysis."
        },
        "driftViewer.impact.maxRowsPerTable": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum rows to fetch per table branch in impact analysis."
        },
        "driftViewer.seeder.defaultRowCount": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "maximum": 10000,
          "description": "Default number of rows to generate per table."
        },
        "driftViewer.seeder.nullProbability": {
          "type": "number",
          "default": 0.05,
          "minimum": 0,
          "maximum": 1,
          "description": "Probability of generating NULL for nullable columns (0.0-1.0)."
        },
        "driftViewer.sqlNotebook.maxHistory": {
          "type": "number",
          "default": 200,
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum number of SQL queries to keep in history."
        },
        "driftViewer.invariants.continuous": {
          "type": "boolean",
          "default": false,
          "description": "Re-evaluate invariants on every database change (may impact performance)."
        },
        "driftViewer.invariants.defaultSeverity": {
          "type": "string",
          "enum": [
            "error",
            "warning",
            "info"
          ],
          "default": "warning",
          "description": "Default severity level for new invariant violations."
        }
      }
    }
