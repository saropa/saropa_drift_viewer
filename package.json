{
  "name": "saropa-drift-advisor-workspace",
  "private": true,
  "description": "Workspace root for saropa_drift_advisor (Dart package + VS Code extension)",
  "scripts": {
    "prepare": "husky",
    "lint:extension": "cd extension && npm run lint",
    "compile:extension": "cd extension && npm run compile",
    "test:extension": "cd extension && npm run test",
    "typecheck:web": "tsc -p tsconfig.web.json --noEmit",
    "build:js": "node esbuild.config.mjs",
    "build:js:watch": "node esbuild.config.mjs --watch",
    "build:style": "sass assets/web/style.scss assets/web/style.css --no-source-map",
    "build:style:watch": "sass assets/web/style.scss assets/web/style.css --watch --no-source-map",
    "build": "npm run build:js && npm run build:style"
  },
  "devDependencies": {
    "esbuild": "^0.28",
    "husky": "^9.1.7",
    "sass": "^1.99",
    "typescript": "^6.0"
  }
}
